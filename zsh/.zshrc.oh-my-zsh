export ZSH="$HOME/.oh-my-zsh"
export PATH="$HOME/.local/bin:$PATH"

ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
  git
)

source "$ZSH/oh-my-zsh.sh"

_dotfiles_zshrc="${(%):-%x}"
_dotfiles_zshrc_dir="${_dotfiles_zshrc:A:h}"
if [[ -r "$HOME/.config/zsh/va.zsh" ]]; then
  source "$HOME/.config/zsh/va.zsh"
elif [[ -r "$_dotfiles_zshrc_dir/.config/zsh/va.zsh" ]]; then
  source "$_dotfiles_zshrc_dir/.config/zsh/va.zsh"
fi
unset _dotfiles_zshrc _dotfiles_zshrc_dir
